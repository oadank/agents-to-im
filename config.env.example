# Feishu / Lark bridge configuration
# Copy to ~/.agents-to-im/config.env and edit
# Scope import JSON and setup notes:
# references/setup-guides.md

# Default working directory for all new sessions
CTI_DEFAULT_WORKDIR=/path/to/your/project

# Feishu / Lark bot
CTI_FEISHU_APP_ID=your-app-id
CTI_FEISHU_APP_SECRET=your-app-secret
# Optional: set to "lark" for Lark international, defaults to Feishu
# CTI_FEISHU_DOMAIN=lark
# Allowlist of senders allowed to drive this bot (open_id / user_id / union_id).
# Required for security: an empty allowlist rejects ALL inbound messages and
# card actions. To explicitly allow every sender (DANGEROUS — see warning below)
# set the value to a single '*' wildcard. Mixing '*' with specific ids is NOT
# treated as wildcard; you must use either '*' alone, or specific ids only.
#
# WARNING: '*' allows anyone who can DM your bot or share a group with it to
# create sessions, run shell commands on this machine, and approve dangerous
# tool calls. Use this only on a personal machine where the bot is privately
# scoped, and switch to your own open_id as soon as you have it.
CTI_FEISHU_ALLOWED_USERS=*
# Example with explicit ids:
# CTI_FEISHU_ALLOWED_USERS=ou_xxx,ou_yyy
# Optional: show separate tool-call activity cards in Feishu/Lark sessions
# (MCP/tool, command execution, and file-change cards).
# Normal assistant reply cards stay enabled either way. Defaults to false.
# CTI_FEISHU_SHOW_TOOL_CALL_CARDS=false

# Optional Claude CLI override.
# Useful on Windows when npm installs `claude.cmd` under %AppData%\Roaming\npm.
# Either the native binary path or the npm shim path is accepted.

# Codex runtime
# Reuses the user's local ~/.codex/config.toml (or $CODEX_HOME/config.toml)
# for auth, trusted directories, sandbox, approval policy, and default model behavior
# Ensure `codex` CLI is already installed and authenticated on this machine

# Optional third-party Claude API passthrough
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
# ANTHROPIC_AUTH_TOKEN=
